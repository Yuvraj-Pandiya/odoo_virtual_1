PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transitops
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=transitops_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# ─── Google OAuth2 ────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# See OAUTH_SETUP.md for step-by-step instructions
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL (used to redirect after OAuth2 completes)
FRONTEND_URL=http://localhost:5173

# Session secret (for OAuth2 state parameter — separate from JWT secret)
SESSION_SECRET=transitops_session_secret_change_in_production
